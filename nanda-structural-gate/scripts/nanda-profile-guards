#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
  script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"
  script_path="$(readlink "$script_path")"
  [[ "$script_path" != /* ]] && script_path="$script_dir/$script_path"
done
script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"
root="$(cd "$script_dir/../.." && pwd)"

repo="."
iterations=50
build_iterations=3
full_iterations=1
format="json"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --iterations)
      iterations="$2"
      shift 2
      ;;
    --build-iterations)
      build_iterations="$2"
      shift 2
      ;;
    --full-iterations)
      full_iterations="$2"
      shift 2
      ;;
    --format)
      format="$2"
      shift 2
      ;;
    --help|-h)
      cat <<'EOF'
Usage: nanda profile-guards [OPTIONS] [REPO]

Profile atlas-first guard workflow wall time.

Options:
  --iterations N        guard-action / guard-diff loop iterations (default: 50)
  --build-iterations N  build-atlas loop iterations (default: 3)
  --full-iterations N   map-code/dogfood loop iterations (default: 1)
  --format json|text    output format (default: json)
EOF
      exit 0
      ;;
    *)
      repo="$1"
      shift
      ;;
  esac
done

if [[ -x "$script_dir/../bin/nanda" ]]; then
  nanda_cmd=("$script_dir/../bin/nanda")
elif [[ -x "$root/target/release/nanda" ]]; then
  nanda_cmd=("$root/target/release/nanda")
else
  nanda_cmd=(cargo run --quiet --manifest-path "$root/Cargo.toml" --)
fi

run_nanda() {
  "${nanda_cmd[@]}" "$@"
}

now_ns() {
  date +%s%N
}

measure_ms() {
  local loops="$1"
  shift
  local start end
  start="$(now_ns)"
  for _ in $(seq 1 "$loops"); do
    "$@" >/dev/null
  done
  end="$(now_ns)"
  echo $(((end - start) / 1000000))
}

measure_serve_ms() {
  local request_file="$1"
  local start end
  start="$(now_ns)"
  run_nanda serve <"$request_file" >/dev/null
  end="$(now_ns)"
  echo $(((end - start) / 1000000))
}

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

atlas="$tmp/route-atlas.json"
build_total_ms="$(measure_ms "$build_iterations" run_nanda build-atlas "$repo" --out "$atlas" --format json)"
run_nanda build-atlas "$repo" --out "$atlas" --format json >/dev/null

pick_route() {
  jq -r '
    if .routes["ime-display-flow"] then "ime-display-flow"
    elif .routes["runtime-flow"] then "runtime-flow"
    elif .routes["manual-trigger-flow"] then "manual-trigger-flow"
    elif (.routes | keys | length) > 0 then (.routes | keys[0])
    else empty end
  ' "$atlas"
}

route="$(pick_route)"
if [[ -z "$route" ]]; then
  echo "error: atlas has no routes" >&2
  exit 2
fi

action_id="$(
  case "$route" in
    ime-display-flow) echo "ime.profile_guard" ;;
    runtime-flow) echo "runtime.profile_guard" ;;
    manual-trigger-flow) echo "manual.profile_guard" ;;
    space-autocorrect-flow) echo "space.profile_guard" ;;
    nanda-field-flow) echo "nanda.profile_guard" ;;
    config-flow) echo "config.profile_guard" ;;
    ui-status-flow) echo "ui.profile_guard" ;;
    install-flow) echo "install.profile_guard" ;;
    test-flow) echo "test.profile_guard" ;;
    *) echo "${route%-flow}.profile_guard" ;;
  esac
)"

symptom="$(
  case "$route" in
    ime-display-flow) echo "IME not visible" ;;
    runtime-flow) echo "runtime state changed" ;;
    manual-trigger-flow) echo "double shift does not trigger" ;;
    *) echo "$route route check" ;;
  esac
)"

allowed_file="$(jq -r --arg route "$route" '.routes[$route].allowed_files[0] // empty' "$atlas")"
if [[ -z "$allowed_file" ]]; then
  echo "error: route has no allowed files: $route" >&2
  exit 2
fi

cat >"$tmp/allowed.diff" <<EOF_DIFF
diff --git a/$allowed_file b/$allowed_file
--- a/$allowed_file
+++ b/$allowed_file
@@ -1 +1 @@
-old
+new
EOF_DIFF

guard_action_total_ms="$(measure_ms "$iterations" run_nanda guard-action "$atlas" --symptom "$symptom" --action-id "$action_id" --format json)"
guard_diff_total_ms="$(measure_ms "$iterations" run_nanda guard-diff "$atlas" --action-id "$action_id" --diff "$tmp/allowed.diff" --format json)"
map_code_total_ms="$(measure_ms "$full_iterations" run_nanda map-code "$repo" --format json)"
dogfood_total_ms="$(measure_ms "$full_iterations" run_nanda dogfood "$repo" --refactor-plan --format json)"

serve_action_requests="$tmp/serve-action.jsonl"
serve_diff_requests="$tmp/serve-diff.jsonl"
serve_combined_requests="$tmp/serve-combined.jsonl"
action_request="$(jq -cn --arg atlas "$atlas" --arg symptom "$symptom" --arg action_id "$action_id" '{command:"guard_action", atlas:$atlas, symptom:$symptom, action_id:$action_id}')"
diff_text="$(cat "$tmp/allowed.diff")"
diff_request="$(jq -cn --arg atlas "$atlas" --arg action_id "$action_id" --arg diff "$diff_text" '{command:"guard_diff", atlas:$atlas, action_id:$action_id, diff:$diff}')"
for _ in $(seq 1 "$iterations"); do
  printf '%s\n' "$action_request" >>"$serve_action_requests"
  printf '%s\n' "$diff_request" >>"$serve_diff_requests"
  printf '%s\n%s\n' "$action_request" "$diff_request" >>"$serve_combined_requests"
done
serve_guard_action_total_ms="$(measure_serve_ms "$serve_action_requests")"
serve_guard_diff_total_ms="$(measure_serve_ms "$serve_diff_requests")"
serve_guard_combined_total_ms="$(measure_serve_ms "$serve_combined_requests")"

avg() {
  local total="$1"
  local loops="$2"
  if [[ "$loops" -le 0 ]]; then
    echo 0
  else
    awk -v total="$total" -v loops="$loops" 'BEGIN { printf "%.3f", total / loops }'
  fi
}

build_avg_ms="$(avg "$build_total_ms" "$build_iterations")"
guard_action_avg_ms="$(avg "$guard_action_total_ms" "$iterations")"
guard_diff_avg_ms="$(avg "$guard_diff_total_ms" "$iterations")"
map_code_avg_ms="$(avg "$map_code_total_ms" "$full_iterations")"
dogfood_avg_ms="$(avg "$dogfood_total_ms" "$full_iterations")"
serve_guard_action_avg_ms="$(avg "$serve_guard_action_total_ms" "$iterations")"
serve_guard_diff_avg_ms="$(avg "$serve_guard_diff_total_ms" "$iterations")"
serve_guard_combined_avg_ms="$(avg "$serve_guard_combined_total_ms" "$((iterations * 2))")"
total_files="$(jq -r '.total_files // 0' "$atlas")"
route_count="$(jq -r '.routes | keys | length' "$atlas")"

if [[ "$format" == "text" ]]; then
  cat <<EOF
NANDA GUARD PROFILE
repo: $repo
atlas_files: $total_files
routes: $route_count
sample_route: $route
build_atlas_avg_ms: $build_avg_ms
guard_action_avg_ms: $guard_action_avg_ms
guard_diff_avg_ms: $guard_diff_avg_ms
serve_guard_action_avg_ms: $serve_guard_action_avg_ms
serve_guard_diff_avg_ms: $serve_guard_diff_avg_ms
serve_guard_combined_per_request_avg_ms: $serve_guard_combined_avg_ms
map_code_repo_avg_ms: $map_code_avg_ms
dogfood_refactor_avg_ms: $dogfood_avg_ms
EOF
else
  jq -n \
    --arg repo "$repo" \
    --arg sample_route "$route" \
    --arg action_id "$action_id" \
    --argjson atlas_files "$total_files" \
    --argjson route_count "$route_count" \
    --argjson build_iterations "$build_iterations" \
    --argjson guard_iterations "$iterations" \
    --argjson full_iterations "$full_iterations" \
    --argjson build_atlas_avg_ms "$build_avg_ms" \
    --argjson guard_action_avg_ms "$guard_action_avg_ms" \
    --argjson guard_diff_avg_ms "$guard_diff_avg_ms" \
    --argjson map_code_repo_avg_ms "$map_code_avg_ms" \
    --argjson dogfood_refactor_avg_ms "$dogfood_avg_ms" \
    --argjson serve_guard_action_avg_ms "$serve_guard_action_avg_ms" \
    --argjson serve_guard_diff_avg_ms "$serve_guard_diff_avg_ms" \
    --argjson serve_guard_combined_avg_ms "$serve_guard_combined_avg_ms" \
    '{
      mode: "guard-profile",
      repo: $repo,
      atlas_files: $atlas_files,
      route_count: $route_count,
      sample_route: $sample_route,
      sample_action_id: $action_id,
      iterations: {
        build_atlas: $build_iterations,
        guard: $guard_iterations,
        full: $full_iterations
      },
      avg_ms: {
        build_atlas: $build_atlas_avg_ms,
        guard_action: $guard_action_avg_ms,
        guard_diff: $guard_diff_avg_ms,
        serve_guard_action: $serve_guard_action_avg_ms,
        serve_guard_diff: $serve_guard_diff_avg_ms,
        serve_guard_combined_per_request: $serve_guard_combined_avg_ms,
        map_code_repo: $map_code_repo_avg_ms,
        dogfood_refactor: $dogfood_refactor_avg_ms
      },
      read_as: "Wall-clock profile. guard_action/guard_diff are cold CLI calls; serve_guard_* keeps one nanda process alive and caches the route atlas for protected edit loops."
    }'
fi
