      "expected_plain_peak": "customs",
      "expected_negative_peak": "customs"
    },
    {
      "id": "group-negative-lane-shifts-customs-shortcut",
      "path": "triad-packet.negative-shortcut-lanes.json",
      "group_by": "group",
      "expected_decision": "SHIFTED_TO_REVIEW",
      "expected_plain_peak": "customs-shortcut",
      "expected_negative_peak": "certification-route"
    },
    {
      "id": "external-negative-lanes-shift-base-packet",
      "path": "triad-packet.negative-shortcut-base.json",
      "negative": ["triad-packet.negative-shortcut-lanes.json"],
      "expected_decision": "SHIFTED_TO_REVIEW",
      "expected_plain_peak": "customs",
      "expected_negative_peak": "certification"
    }
