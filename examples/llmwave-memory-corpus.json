{
  "name": "llmwave-memory-corpus",
  "cases": [
    {
      "id": "retrieve-payment-from-customs-prefix",
      "path": "triad-packet.interference-search-route-trap.json",
      "write_text": "customs declaration requires payment",
      "prefix": "customs declaration requires",
      "expected_top_token": "payment",
      "expected_state": "MEMORY_RETRIEVE_READY",
      "expected_generated_contains": "payment",
      "steps": 2
    },
    {
      "id": "feedback-reject-protocols-keeps-payment",
      "path": "triad-packet.interference-search-route-trap.json",
      "write_text": "declaration requires protocols",
      "prefix": "declaration requires",
      "expected_top_token": "payment",
      "expected_state": "MEMORY_RETRIEVE_READY",
      "expected_generated_contains": "payment",
      "feedback": [
        {
          "decision": "reject",
          "token": "protocols",
          "note": "false shortcut"
        }
      ],
      "consolidate": true,
      "steps": 2
    },
    {
      "id": "text-trained-payment-continuation",
      "train_text_path": "llmwave-tiny-corpus.txt",
      "prefix": "customs declaration requires",
      "expected_top_token": "payment",
      "expected_state": "MEMORY_RETRIEVE_READY",
      "expected_generated_contains": "payment",
      "expected_memory_version": "v101-training-from-text",
      "steps": 2
    },
    {
      "id": "grown-business-memory-supplier-issues",
      "path": "triad-packet.interference-search-route-trap.json",
      "grow_path": "triad-packet.token-lens-business.json",
      "prefix": "supplier issues",
      "expected_top_token": "invoice",
      "expected_state": "MEMORY_RETRIEVE_READY",
      "expected_generated_contains": "invoice",
      "steps": 2
    },
    {
      "id": "decay-keeps-strong-payment-route",
      "path": "triad-packet.interference-search-route-trap.json",
      "prefix": "customs declaration requires",
      "expected_top_token": "payment",
      "expected_state": "MEMORY_RETRIEVE_READY",
      "expected_generated_contains": "payment",
      "decay_factor": 0.99,
      "steps": 2
    },
    {
      "id": "prompt-adapter-question-to-prefix",
      "train_text_path": "llmwave-tiny-corpus.txt",
      "prompt": "what does customs declaration require?",
      "expected_top_token": "payment",
      "expected_state": "MEMORY_RETRIEVE_READY",
      "expected_generated_contains": "payment",
      "expected_answer_state": "ANSWER_READY",
      "expected_answer_contains": "customs declaration requires payment confirmation",
      "expected_memory_version": "v101-training-from-text",
      "steps": 2
    },
    {
      "id": "qa-who-issues-invoice",
      "train_text_path": "llmwave-tiny-corpus.txt",
      "prompt": "who issues invoice?",
      "expected_answer_state": "ANSWER_READY",
      "expected_answer_contains": "supplier issues invoice",
      "expected_memory_version": "v101-training-from-text",
      "facts": 3
    },
    {
      "id": "qa-what-supports-declaration",
      "train_text_path": "llmwave-tiny-corpus.txt",
      "prompt": "what supports customs declaration?",
      "expected_answer_state": "ANSWER_READY",
      "expected_answer_contains": "payment confirmation supports customs declaration",
      "expected_memory_version": "v101-training-from-text",
      "facts": 3
    },
    {
      "id": "qa-who-pays-supplier",
      "train_text_path": "llmwave-tiny-corpus.txt",
      "prompt": "who pays supplier?",
      "expected_answer_state": "ANSWER_READY",
      "expected_answer_contains": "buyer pays supplier",
      "expected_memory_version": "v101-training-from-text",
      "facts": 3
    }
  ]
}
